{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ai-plugins.toml",
  "type": "object",
  "required": ["plugins"],
  "properties": {
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "enabled"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "desc": { "type": "string" },
          "repo": { "type": "string" },
          "claude": {
            "type": "object",
            "required": ["slug"],
            "additionalProperties": false,
            "properties": {
              "slug": { "type": "string", "minLength": 1 }
            }
          },
          "gemini": {
            "type": "object",
            "required": ["source", "name"],
            "additionalProperties": false,
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 }
            }
          },
          "codex": {
            "type": "object",
            "required": ["marketplace", "slug"],
            "additionalProperties": false,
            "properties": {
              "marketplace": { "type": "string", "minLength": 1 },
              "slug": { "type": "string", "minLength": 1 }
            }
          },
          "cursor": {
            "type": "object",
            "required": ["slug"],
            "additionalProperties": false,
            "properties": {
              "slug": { "type": "string", "minLength": 1 },
              "url": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
