{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "registry.toml",
  "type": "object",
  "properties": {
    "modules": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "module", "desc", "cost", "license", "enabled", "platforms"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "module": { "type": "string", "minLength": 1 },
          "desc": { "type": "string", "minLength": 1 },
          "cost": { "enum": ["free", "freemium", "paid"] },
          "license": { "type": "string" },
          "repo": { "type": "string" },
          "enabled": { "type": "boolean" },
          "platforms": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["macos", "linux"] }
          },
          "macos": { "$ref": "#/definitions/osEntry" },
          "linux": { "$ref": "#/definitions/osEntry" }
        }
      }
    }
  },
  "definitions": {
    "osEntry": {
      "type": "object",
      "required": ["method"],
      "properties": {
        "method": { "enum": ["brew", "cask", "mas", "npm", "script", "apt", "dnf"] },
        "pkg": { "type": "string" },
        "id": {},
        "check": { "type": "string" },
        "cmd": { "type": "string" }
      }
    }
  }
}
