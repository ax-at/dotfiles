{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "skills.toml",
  "type": "object",
  "required": ["agents", "repos"],
  "properties": {
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["repo", "skills"],
        "additionalProperties": false,
        "properties": {
          "repo": { "type": "string", "minLength": 1 },
          "skills": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "agents": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
