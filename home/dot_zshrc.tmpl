# ~/.zshrc — interactive shell config (managed by chezmoi).

# ---- History ---------------------------------------------------------------
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_REDUCE_BLANKS INC_APPEND_HISTORY
setopt AUTO_CD INTERACTIVE_COMMENTS

# ---- Plugins (antidote) ----------------------------------------------------
{{ if eq .chezmoi.os "darwin" -}}
ANTIDOTE_DIR="$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh"
{{ else -}}
ANTIDOTE_DIR="$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh"
{{ end -}}
if [ -f "$ANTIDOTE_DIR" ]; then
  source "$ANTIDOTE_DIR"
  antidote load "${ZDOTDIR:-$HOME}/.zsh_plugins.txt"
fi

# ---- Keybindings -----------------------------------------------------------
# history-substring-search: up/down arrows filter history by the typed prefix.
# Guarded on the widget existing (plugin loaded) so we never clobber the
# defaults if the plugin is missing. Up/down aren't otherwise claimed here —
# fzf binds ^R/^T/^[c, autosuggestions accepts with the right arrow. We bind
# both normal (^[[A/B) and application-mode (^[OA/B) sequences plus the terminfo
# entries so it works across terminals (Ghostty, tmux, SSH).
if (( ${+widgets[history-substring-search-up]} )); then
  bindkey '^[[A' history-substring-search-up
  bindkey '^[OA' history-substring-search-up
  bindkey '^[[B' history-substring-search-down
  bindkey '^[OB' history-substring-search-down
  [[ -n "${terminfo[kcuu1]}" ]] && bindkey "${terminfo[kcuu1]}" history-substring-search-up
  [[ -n "${terminfo[kcud1]}" ]] && bindkey "${terminfo[kcud1]}" history-substring-search-down
fi

# ---- Tooling init ----------------------------------------------------------
command -v mise     >/dev/null 2>&1 && eval "$(mise activate zsh)"
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"
command -v zoxide   >/dev/null 2>&1 && eval "$(zoxide init zsh)"
if command -v fzf >/dev/null 2>&1; then
  source <(fzf --zsh) 2>/dev/null || true
fi

# ---- Environment -----------------------------------------------------------
export EDITOR="nano"
export VISUAL="nano"
export PAGER="less"

{{ if index .modules "react-native" -}}
# Android SDK (set up by Android Studio first-run).
export ANDROID_HOME="$HOME/Library/Android/sdk"
export PATH="$ANDROID_HOME/emulator:$ANDROID_HOME/platform-tools:$PATH"
# JAVA_HOME comes from mise (zulu-17).
command -v mise >/dev/null 2>&1 && export JAVA_HOME="$(mise where java 2>/dev/null || true)"
{{ end -}}

# >>> proton-pass-doctor >>>
# Health check for the Proton Pass secrets pipeline, following the `<tool>
# doctor` diagnostics convention (cf. `brew doctor`, `flutter doctor`): a
# read-only check that exits non-zero when something is wrong. It verifies the
# whole chain end to end — pass-cli is installed, a session is active, and a
# `pass://` reference actually resolves to a real value at invocation time.
# The pass:// string is a reference *locator*, never a secret.
export PROTON_PASS_CANARY="pass://test/chezmoi-test/password"
proton-pass-doctor() {
  command -v pass-cli >/dev/null 2>&1 \
    || { echo "proton-pass-doctor: pass-cli not installed"; return 1; }
  pass-cli info >/dev/null 2>&1 \
    || { echo "proton-pass-doctor: not logged in (run: pass-cli login)"; return 1; }
  local resolved
  resolved="$(pass-cli run -- sh -c 'printf %s "$PROTON_PASS_CANARY"')"
  case "$resolved" in
    "" | pass://*)
      echo "proton-pass-doctor: session active but canary did not resolve ($PROTON_PASS_CANARY)"
      return 1 ;;
    *)
      echo "proton-pass-doctor: OK — secrets pipeline resolves"
      return 0 ;;
  esac
}
# <<< proton-pass-doctor <<<

# ---- Aliases ---------------------------------------------------------------
alias ls='eza --icons --group-directories-first'
alias ll='eza -lah --icons --group-directories-first'
alias lt='eza --tree --level=2 --icons'
alias cat='bat --paging=never'
alias cd..='cd ..'
alias ..='cd ..'
alias ...='cd ../..'
alias g='git'
alias gs='git status'
alias reload='exec zsh'
# mkcd: make a directory and cd into it (OMZ also provides `take`).
mkcd() { mkdir -p "$1" && cd "$1"; }

# Maintenance: update everything in one shot.
update-all() {
  brew update && brew upgrade && brew cleanup
  mise upgrade
  chezmoi update
}

# ---- Local overrides (never committed) -------------------------------------
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
