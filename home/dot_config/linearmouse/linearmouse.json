{
  "$schema": "https:\/\/schema.linearmouse.app\/0.11.2",
  "schemes": [
    {
      "pointer": {
        "acceleration": 0,
        "disableAcceleration": true,
        "speed": 0.4
      },
      "scrolling": {
        "distance": 3,
        "reverse": false
      }
    },
    {
      "if": {
        "device": {
          "category": "mouse",
          "productID": "0x60ef",
          "productName": "Lenovo Bluetooth Mouse",
          "serialNumber": "000000000000000",
          "vendorID": "0x17ef"
        }
      },
      "pointer": {
        "acceleration": "unset",
        "disableAcceleration": false,
        "redirectsToScroll": false,
        "speed": "unset"
      },
      "scrolling": {
        "acceleration": {
          "vertical": 1
        },
        "distance": {
          "vertical": "auto"
        },
        "modifiers": {
          "vertical": {
            "control": {
              "type": "auto"
            }
          }
        },
        "smoothed": {
          "vertical": {
            "enabled": false
          }
        },
        "speed": {
          "vertical": 0
        }
      }
    }
  ]
}
