# Ghostty config (managed by chezmoi). Plain text → versions cleanly.

font-family = "JetBrainsMono Nerd Font"
font-size = 14
# Ghostty ships this built-in (see `ghostty +list-themes`). Name is exact —
# "catppuccin-mocha" does NOT match and errors on every launch. Validity is
# guarded by test/ghostty_theme.bats.
theme = "Catppuccin Mocha"

background-opacity = 0.98
window-padding-x = 10
window-padding-y = 8
cursor-style = block
mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false

# macOS: use Option as Alt (so word-nav etc. behave as expected).
{{ if eq .chezmoi.os "darwin" -}}
macos-option-as-alt = true
{{ end -}}

# Keybinds
keybind = cmd+k=clear_screen
