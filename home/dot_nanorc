# ~/.nanorc — lean defaults for the primary terminal editor.
set linenumbers
set softwrap
set tabstospaces
set tabsize 2
set autoindent
set constantshow
set mouse
set smarthome
set trimblanks

# Syntax highlighting bundled with nano.
include "/opt/homebrew/share/nano/*.nanorc"
include "/usr/local/share/nano/*.nanorc"
include "/usr/share/nano/*.nanorc"
