#!/usr/bin/env bash
# run_onchange_after_50-editor-extensions.sh
# Installs the shared extension set into VS Code, Cursor, and Antigravity IDE
# (whichever exist). Re-runs when this list changes.
#
# Logic lives in functions + main() so the rendered script can be sourced by
# the test suite without executing side effects (see the BASH_SOURCE guard at
# the bottom). The `exit 0` module gate and `set -euo pipefail` live inside
# main() so sourcing never exits the caller or flips its shell options.

EXTENSIONS=(
  # Lint/format — Ultracite via Oxc (oxlint + oxfmt). No ESLint/Prettier.
  oxc.oxc-vscode
  # React Native / web
  expo.vscode-expo-tools
  msjsdiag.vscode-react-native
  bradlc.vscode-tailwindcss
  # DX
  eamodio.gitlens
  usernamehw.errorlens
  editorconfig.editorconfig
  christian-kohler.npm-intellisense
  yoavbls.pretty-ts-errors
  yzane.markdown-pdf
  # Language support used in this repo
  tamasfe.even-better-toml
  timonwong.shellcheck
  foxundermoon.shell-format
  redhat.vscode-yaml
  github.vscode-github-actions
  yzhang.markdown-all-in-one
  highagency.pencildev
)

install_into() {
  local bin="$1" label="$2"
  command -v "$bin" >/dev/null 2>&1 || { echo "  ($label not on PATH — skipping)"; return; }
  echo "==> [extensions] $label"
  local installed; installed="$("$bin" --list-extensions 2>/dev/null | tr '[:upper:]' '[:lower:]')"
  # Collect only what's missing, then install it all in ONE invocation. These
  # CLIs cold-start a full editor host per call (very slow on Antigravity IDE),
  # so a single call with repeated --install-extension flags beats one call per
  # extension by a wide margin.
  local ext missing=() args=()
  for ext in "${EXTENSIONS[@]}"; do
    if grep -qx "$(echo "$ext" | tr '[:upper:]' '[:lower:]')" <<<"$installed"; then
      echo "  ✓ $ext"
    else
      missing+=("$ext")
      args+=(--install-extension "$ext")
    fi
  done
  [ "${#missing[@]}" -eq 0 ] && return 0
  # stdout is just progress chatter — drop it. On stderr, strip only Antigravity
  # IDE's benign "depends on antigravityAnalytics which is NOT registered" line
  # (its telemetry service is GUI-only); real errors ("not found", "Failed
  # Installing Extensions") still pass through. Exit status is unaffected.
  if "$bin" "${args[@]}" --force >/dev/null \
       2> >(grep -v 'antigravityAnalytics which is NOT registered' >&2); then
    printf '  + %s\n' "${missing[@]}"
  else
    printf '  ! %s: one or more extensions failed to install (see above)\n' "$label" >&2
  fi
}

main() {
  set -euo pipefail
{{ if not (index .modules "editors") }}  exit 0
{{ end }}
  install_into code   "VS Code"
  install_into cursor "Cursor"
  install_into agy-ide "Antigravity IDE"
  echo "==> [extensions] done"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then main "$@"; fi
