#!/usr/bin/env bash
# run_onchange_after_20-packages.sh
# Generates a Brewfile from the enabled registry entries and runs `brew bundle`.
# Re-runs automatically whenever the rendered package list below changes.
set -euo pipefail

{{- $os := "macos" }}{{ if eq .chezmoi.os "linux" }}{{ $os = "linux" }}{{ end }}

# Ensure brew is on PATH.
if [ -x /opt/homebrew/bin/brew ]; then eval "$(/opt/homebrew/bin/brew shellenv)";
elif [ -x /usr/local/bin/brew ]; then eval "$(/usr/local/bin/brew shellenv)";
elif [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)";
fi
command -v brew >/dev/null 2>&1 || { echo "brew not found; run prerequisites first" >&2; exit 1; }

BREWFILE="$(mktemp)"
trap 'rm -f "$BREWFILE"' EXIT

cat >"$BREWFILE" <<'BREWFILE_EOF'
# Generated from registry.toml — do not edit by hand.
{{ range .packages -}}
{{- if and .enabled (index $.modules .module) (has $os .platforms) -}}
{{- $p := index . $os -}}
{{- if eq $p.method "brew" }}brew "{{ $p.pkg }}"
{{ else if eq $p.method "cask" }}cask "{{ $p.pkg }}"
{{ else if eq $p.method "mas" }}mas "{{ $p.pkg }}", id: {{ $p.id }}
{{ end -}}
{{- end -}}
{{- end -}}
BREWFILE_EOF

echo "==> [packages] brew bundle:"
cat "$BREWFILE"
# HOMEBREW_NO_REQUIRE_TAP_TRUST: some registry entries live in third-party taps
# (e.g. hunk in modem-dev/tap). Homebrew's tap-trust check refuses to load
# formulae from untrusted taps non-interactively, which aborts the whole bundle.
# These taps are intentional, curated entries in registry.toml, so we opt into
# trusting them for this bundle run. (Scoped to the command, not exported.)
# --verbose: stream each formula/cask's download + install output live instead
# of buffering it, so `chezmoi apply` shows real progress rather than a single
# static "Fetching ..." line while large casks download.
HOMEBREW_NO_REQUIRE_TAP_TRUST=1 brew bundle --verbose --file="$BREWFILE"

# Persistently trust the third-party taps referenced above (recorded by
# `brew trust` in trust.json). The bundle run bypasses the tap-trust gate for
# itself, but this also lets *interactive* brew commands (brew list/info/upgrade)
# load these casks/formulae without the "untrusted tap" refusal, in case a
# future Homebrew enables HOMEBREW_REQUIRE_TAP_TRUST by default. Derived from the
# full "org/tap/name" entries in the Brewfile; runs after bundle so the taps are
# already tapped; per-tap failures are non-fatal.
if brew trust --help >/dev/null 2>&1; then
  grep -oE '"[A-Za-z0-9_-]+/[A-Za-z0-9_-]+/[^"]+"' "$BREWFILE" |
    tr -d '"' | sed 's#/[^/]*$##' | sort -u |
    while read -r tap; do brew trust "$tap" 2>/dev/null || true; done
fi
echo "==> [packages] done"
