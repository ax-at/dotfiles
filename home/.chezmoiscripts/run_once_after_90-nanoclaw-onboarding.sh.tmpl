#!/usr/bin/env bash
# run_once_after_90-nanoclaw-onboarding.sh
# nanoclaw-v2 is cloned earlier (registry entry -> run_onchange_after_40-ai-tools).
# This runs dead-last and offers to run the interactive onboarding (nanoclaw.sh)
# now, or prints how to run it later. Deferrable; it never fails the apply.
# Idempotent: a checkout that already has a .env (onboarded) is left untouched,
# which also makes this safe to re-fire if the script's content ever changes
# (run_once keys on the script's SHA). Gated on the nanoclaw module.
# On macOS, before handing off, it ensures the Docker engine is actually running
# (starts OrbStack/Docker and waits) -- nanoclaw's container step hard-requires a
# live engine and its own auto-start only knows Docker Desktop, not OrbStack.
# It also runs the whole onboarding under the mise-resolved, .nvmrc-pinned node
# (via `mise exec`): nanoclaw compiles a native module (better-sqlite3) and bakes
# `command -v node` into its launchd/systemd service, so the BUILD node and the
# SERVICE node must match. A bare `node` on a fresh non-login apply resolves to
# Homebrew's floating node (a transitive oxfmt dep) and mismatches nanoclaw's
# pin -> ERR_DLOPEN_FAILED at boot.
set -euo pipefail

{{ if .modules.nanoclaw -}}
DIR="$HOME/nanoclaw-v2"

# Clone gated off or failed earlier -> nothing to onboard.
if [ ! -d "$DIR" ]; then
  echo "==> [nanoclaw] $DIR not present; skipping onboarding"
  exit 0
fi

# Already configured (.env written during onboarding) -> leave it untouched.
if [ -f "$DIR/.env" ]; then
  echo "==> [nanoclaw] already onboarded ($DIR/.env present); skipping"
  exit 0
fi

print_later() {
  echo ""
  echo "==> [nanoclaw] onboarding deferred. Finish it any time with:"
  echo "      cd $DIR && mise install node && mise exec -- bash nanoclaw.sh"
  echo ""
}

# Non-interactive apply (CI, piped) -> never block; defer with instructions.
if [ ! -t 0 ]; then
  echo "==> [nanoclaw] non-interactive shell; deferring onboarding"
  print_later
  exit 0
fi

printf '==> [nanoclaw] Run onboarding now? Interactive, may take a while. [y/N] '
read -r ans || ans="n"
case "$ans" in
  y | Y | yes | Yes | YES)
{{ if eq .chezmoi.os "darwin" -}}
    # nanoclaw's container step REQUIRES a running Docker engine and hard-exits
    # (runtime_not_available) without one. Its own auto-start is hardcoded
    # `open -a Docker` (Docker Desktop), so on an OrbStack machine the engine
    # never comes up and onboarding aborts with "Couldn't prepare the sandbox".
    # Bring the engine up ourselves first, then hand off. PATH is augmented
    # because a fresh (non-login) chezmoi apply hasn't sourced the profile that
    # puts OrbStack's docker (~/.orbstack/bin) on PATH -- and the child
    # nanoclaw.sh calls `docker` by bare name, so it inherits this PATH too.
    export PATH="$HOME/.orbstack/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"
    if ! docker info >/dev/null 2>&1; then
      app=""
      if [ -d "/Applications/OrbStack.app" ]; then
        app="OrbStack"
      elif [ -d "/Applications/Docker.app" ]; then
        app="Docker"
      fi
      if [ -z "$app" ]; then
        echo "==> [nanoclaw] no Docker runtime found (OrbStack/Docker Desktop)." >&2
        echo "==> [nanoclaw] install or start one, then resume onboarding." >&2
        print_later
        exit 0
      fi
      echo "==> [nanoclaw] Docker engine not running; starting $app and waiting..."
      open -a "$app" || true
      i=0
      until docker info >/dev/null 2>&1; do
        i=$((i + 1))
        if [ "$i" -ge 30 ]; then # 30 x 2s = ~60s
          echo "" >&2
          echo "==> [nanoclaw] $app didn't come up in time; deferring onboarding." >&2
          print_later
          exit 0
        fi
        printf '.'
        sleep 2
      done
      echo ""
      echo "==> [nanoclaw] Docker engine is up."
    fi
    # nanoclaw's launchd/systemd service uses a HARDCODED PATH
    # (/usr/local/bin:/usr/bin:/bin:~/.local/bin -- setup/service.ts) and calls
    # `docker` by bare name for its container-runtime check. That assumes Docker
    # Desktop (which symlinks docker into /usr/local/bin); OrbStack keeps docker
    # at ~/.orbstack/bin, which that PATH omits -- so the service hard-exits with
    # "Container runtime failed to start" even while the engine is up. Bridge it:
    # if the docker we resolve isn't already on the service PATH, symlink it into
    # ~/.local/bin (which IS on it). Survives plist regen; only created when
    # ~/.local/bin/docker is free, so a user-placed docker is never clobbered.
    docker_bin="$(command -v docker 2>/dev/null || true)"
    case "$docker_bin" in
      "" | /usr/local/bin/docker | /usr/bin/docker | /bin/docker | "$HOME/.local/bin/docker") : ;;
      *)
        if [ ! -e "$HOME/.local/bin/docker" ]; then
          mkdir -p "$HOME/.local/bin"
          ln -sf "$docker_bin" "$HOME/.local/bin/docker"
          echo "==> [nanoclaw] linked $docker_bin -> ~/.local/bin/docker (for the service's PATH)"
        fi
        ;;
    esac
{{ end -}}
    # Pin node for the onboarding (see header). brew installs mise (core pkg), so
    # put mise on PATH cross-platform via the repo idiom (cf. run_onchange_after_30
    # -mise). Every miss soft-fails (defer + exit 0) -- this script never fails the
    # apply. This block is OUTSIDE the darwin guard above: the ABI split hits Linux
    # too. The darwin PATH export (OrbStack first, for docker) already ran and the
    # engine is up; brew shellenv here is benign and mise exec prepends node anyway.
    if [ -x /opt/homebrew/bin/brew ]; then eval "$(/opt/homebrew/bin/brew shellenv)";
    elif [ -x /usr/local/bin/brew ]; then eval "$(/usr/local/bin/brew shellenv)";
    elif [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)";
    fi
    if ! command -v mise >/dev/null 2>&1; then
      echo "==> [nanoclaw] mise not on PATH; cannot pin node -- deferring." >&2
      print_later
      exit 0
    fi
    # cd so mise resolves nanoclaw's .nvmrc. Install the pinned node
    # (not_found_auto_install=false won't auto-fetch). pnpm is NOT installed here:
    # nanoclaw's setup.sh runs `corepack enable`, and under `mise exec` pnpm
    # resolves to node's corepack shim (matching nanoclaw's packageManager pin).
    cd "$DIR" || { print_later; exit 0; }
    if ! mise install node; then
      echo "==> [nanoclaw] 'mise install node' failed -- deferring." >&2
      print_later
      exit 0
    fi
    # Light guard: require a REAL mise-managed node path (not a shim / brew
    # fallthrough). Assert resolution, not a specific major -- .nvmrc stays the
    # source of truth, so an upstream .nvmrc bump is followed automatically.
    node_bin="$(mise which node 2>/dev/null || true)"
    case "$node_bin" in
      */installs/node/*) : ;;
      *)
        echo "==> [nanoclaw] mise did not resolve a project node (.nvmrc) -- deferring." >&2
        print_later
        exit 0
        ;;
    esac
    echo "==> [nanoclaw] onboarding under node: $node_bin"
    echo "==> [nanoclaw] launching nanoclaw.sh (resumable; Ctrl-C to abort)"
    if ! mise exec -- bash "$DIR/nanoclaw.sh"; then
      {
        echo ""
        echo "==> [nanoclaw] onboarding did not finish. Resume any time with:"
        echo "      cd $DIR && mise install node && mise exec -- bash nanoclaw.sh"
        echo ""
      } >&2
    fi
    ;;
  *)
    print_later
    ;;
esac
{{ else -}}
exit 0
{{ end -}}
